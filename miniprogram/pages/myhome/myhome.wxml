<!--pages/myhome/myhome.wxml-->
<view class="page">
  <!-- 用户头部（统一布局） -->
  <view class="user-header">
    <view class="user-main">
      <view class="user-avatar">
        <image src="{{userInfo && userInfo.avatarUrl ? userInfo.avatarUrl : '/images/tabBar/me.png'}}" mode="aspectFill"></image>
      </view>
      <view class="user-detail">
        <view class="user-name" wx:if="{{userInfo.nickName}}">
          {{userInfo && userInfo.nickName ? userInfo.nickName : '餐饮会员'}}
        </view>
        <view class="user-phone login-prompt-text" wx:if="{{!userInfo || !userInfo.nickName}}">
          请先完善个人信息
        </view>
        <button
          class="login-btn-inline"
          wx:if="{{!userInfo || !userInfo.nickName}}"
          bindtap="showAuthModal">
          点击完善个人信息
        </button>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <!-- <view class="menu-section">
    <van-grid column-num="2" border="{{false}}" custom-class="service-grid">
      <van-grid-item custom-class="service-item">
        <button class="service-btn" open-type="contact">
          <view class="service-icon">💬</view>
          <view class="service-text">联系客服</view>
        </button>
      </van-grid-item>
      <van-grid-item custom-class="service-item">
        <button class="service-btn" open-type="contact">
          <view class="service-icon">📞</view>
          <view class="service-text">在线咨询</view>
        </button>
      </van-grid-item>
    </van-grid>
  </view> -->

  <!-- 管理员入口触发区域（隐藏在右下角） -->
  <view class="admin-trigger" bindtap="onAdminTrigger"></view>

  <!-- 密码输入弹窗 -->
  <view class="modal-mask" wx:if="{{showPasswordModal}}" catchtap="noop">
    <view class="modal-dialog" catchtap="stopPropagation">
      <view class="modal-title">{{isFirstTime ? '设置管理员密码' : '管理员登录'}}</view>
      <view class="modal-content">
        <input 
          class="password-input" 
          type="password" 
          placeholder="{{isFirstTime ? '请设置管理员密码（至少6位）' : '请输入管理员密码'}}" 
          value="{{adminPassword}}"
          bindinput="onPasswordInput"
        />
        <view class="password-hint" wx:if="{{isFirstTime}}">
          首次设置，请设置一个安全的密码
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="closePasswordModal">取消</view>
        <view class="modal-btn confirm" bindtap="verifyPassword">{{isFirstTime ? '设置' : '登录'}}</view>
      </view>
    </view>
  </view>

  <!-- 用户信息授权组件 -->
  <avatar-nickname-modal 
    showAvaModal="{{showAuthModal}}" 
    bind:saved="onUserInfoSaved">
  </avatar-nickname-modal>

  <!-- 版本号显示 -->
  <view class="version-info">
    <text class="version-text">版本号：{{version}}</text>
  </view>
</view>
